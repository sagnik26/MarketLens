# Copy to .env or .env.local and fill in real values.
# Next.js loads .env* from the project root.

# App
NODE_ENV=development

# MongoDB (required for Competitor Radar and persistence)
MONGODB_URI=mongodb://localhost:27017/marketlens

# Redis (optional; for future rate limiting / caching)
REDIS_URL=redis://localhost:6379

# TinyFish API (required for scan runs and compliance)
TINYFISH_API_KEY=
