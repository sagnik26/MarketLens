# Copy to .env or .env.local and fill in real values.
# Next.js loads .env* from the project root.

# App
NODE_ENV=development

# MongoDB (required for Competitor Radar and persistence)
MONGODB_URI=mongodb://localhost:27017/marketlens

# Redis (optional; for future rate limiting / caching)
REDIS_URL=redis://localhost:6379

# TinyFish API (required for scan runs and compliance)
TINYFISH_API_KEY=

# JWT auth (required in production)
# Secrets must be at least 32 characters and kept private.
JWT_ACCESS_SECRET=your-access-secret-minimum-32-characters
JWT_REFRESH_SECRET=your-refresh-secret-minimum-32-characters

# Optional: override default token lifetimes used by jsonwebtoken.
# Format examples: "15m", "1h", "7d". Defaults if unset:
# - JWT_ACCESS_EXPIRES_IN: 15m
# - JWT_REFRESH_EXPIRES_IN: 7d
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
