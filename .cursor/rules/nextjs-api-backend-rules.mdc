## 13. MongoDB Transactions

- ALWAYS use Mongoose sessions for operations that touch multiple collections.
- NEVER rely on application-level rollback — use MongoDB sessions for atomicity.
- ALWAYS abort the session in the catch block.
- NOTE: MongoDB transactions require a **Replica Set** or **MongoDB Atlas** (not standalone).

```typescript
// Example: create order and decrement inventory atomically
import mongoose from 'mongoose'
import { dbConnect } from '@/server/lib/db'

export async function createOrderWithInventory(orderData: CreateOrderDto) {
  await dbConnect()
  const session = await mongoose.startSession()

  try {
    session.startTransaction()

    const order = await OrderModel.create([orderData], { session })
    await InventoryModel.findByIdAndUpdate(
      orderData.itemId,
      { $inc: { stock: -orderData.quantity } },
      { session, new: true }
    )

    await session.commitTransaction()
    return order[0]
  } catch (error) {
    await session.abortTransaction()
    throw error
  } finally {
    session.endSession()
  }
}
```

