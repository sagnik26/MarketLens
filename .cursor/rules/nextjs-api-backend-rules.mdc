## 22. Testing

- ALWAYS use `vitest` for unit and integration tests.
- ALWAYS use `mongodb-memory-server` for integration tests — never hit Atlas in tests.
- ALWAYS mock repositories in unit tests for services.
- ALWAYS reset the in-memory database between tests with `beforeEach`.
- ALWAYS mock Redis in unit tests.
- Aim for >80% coverage on services and repositories.

```typescript
// server/services/users.service.test.ts
import { describe, it, expect, vi, beforeEach } from 'vitest'
import { userService } from './users.service'
import { userRepository } from '@/server/repositories/users.repository'
import { NotFoundError, ConflictError } from '@/server/api/errors'

vi.mock('@/server/repositories/users.repository')

describe('userService', () => {
  beforeEach(() => vi.clearAllMocks())

  it('throws NotFoundError when user does not exist', async () => {
    vi.mocked(userRepository.findById).mockResolvedValue(null)
    await expect(userService.getById('64abc1234567890123456789')).rejects.toThrow(NotFoundError)
  })

  it('throws ConflictError when email already exists', async () => {
    vi.mocked(userRepository.findByEmail).mockResolvedValue({ id: '1' } as any)
    await expect(
      userService.create({ email: 'a@b.com', name: 'Test', password: 'pass1234' })
    ).rejects.toThrow(ConflictError)
  })
})

// server/repositories/users.repository.test.ts — integration test with in-memory MongoDB
import { MongoMemoryServer } from 'mongodb-memory-server'
import mongoose from 'mongoose'
import { userRepository } from './users.repository'

let mongod: MongoMemoryServer

beforeAll(async () => {
  mongod = await MongoMemoryServer.create()
  await mongoose.connect(mongod.getUri())
})

afterAll(async () => {
  await mongoose.disconnect()
  await mongod.stop()
})

afterEach(async () => {
  await mongoose.connection.dropDatabase()
})
```

