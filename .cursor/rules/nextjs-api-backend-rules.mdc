## 10. Service Layer

- Business logic ONLY lives in services.
- Services are HTTP-agnostic — no `NextRequest`, no `Response`, no status codes.
- Services throw `HttpError` subclasses for expected errors.
- Services call repositories and other services. NEVER touch Mongoose/MongoDB directly.
- Services are shared between Route Handlers AND Server Actions.

```typescript
// server/services/users.service.ts
import { userRepository } from '@/server/repositories/users.repository'
import { NotFoundError, ConflictError } from '@/server/api/errors'
import { hashPassword } from '@/server/lib/auth/password'
import type { CreateUserDto, UpdateUserDto } from '@/types/users.types'

export const userService = {
  async getById(id: string) {
    const user = await userRepository.findById(id)
    if (!user) throw new NotFoundError('User')
    return user
  },

  async getMany({ page, limit }: { page?: number; limit?: number }) {
    return userRepository.findMany({ page, limit, filter: { isActive: true } })
  },

  async create(data: CreateUserDto) {
    const existing = await userRepository.findByEmail(data.email)
    if (existing) throw new ConflictError('User')
    const hashedPassword = await hashPassword(data.password)
    return userRepository.create({ ...data, password: hashedPassword })
  },

  async update(id: string, data: UpdateUserDto) {
    await this.getById(id) // throws NotFoundError if not found
    const updated = await userRepository.update(id, data)
    if (!updated) throw new NotFoundError('User')
    return updated
  },

  async delete(id: string) {
    await this.getById(id)
    await userRepository.delete(id)
  },
}
```

