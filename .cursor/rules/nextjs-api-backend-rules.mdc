## 6. Typed Response Helpers

- ALWAYS return a consistent envelope: `{ success, data, error, meta }`.
- NEVER return raw data without wrapping it.
- ALWAYS use `Response.json()` via these helpers.

```typescript
// server/api/response.ts
interface ApiSuccessResponse<T> {
  success: true
  data: T
  meta?: Record<string, unknown>
}

interface ApiErrorResponse {
  success: false
  error: { message: string; code?: string }
}

export function apiSuccess<T>(data: T, status = 200, meta?: Record<string, unknown>): Response {
  const body: ApiSuccessResponse<T> = { success: true, data, ...(meta && { meta }) }
  return Response.json(body, { status })
}

export function apiError(message: string, status = 500, code?: string): Response {
  const body: ApiErrorResponse = { success: false, error: { message, ...(code && { code }) } }
  return Response.json(body, { status })
}

export function apiPaginated<T>(
  data: T[],
  { total, page, limit }: { total: number; page: number; limit: number }
): Response {
  return apiSuccess(data, 200, { total, page, limit, totalPages: Math.ceil(total / limit) })
}
```

