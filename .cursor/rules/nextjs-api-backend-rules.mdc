## 16. Webhooks

- ALWAYS verify the webhook signature with the raw body BEFORE processing.
- ALWAYS use `req.text()` — never `req.json()` for webhooks (signature verification needs raw bytes).
- ALWAYS respond 200 immediately and process async.
- ALWAYS use `export const dynamic = 'force-dynamic'` on webhook routes.

```typescript
// app/api/v1/webhooks/stripe/route.ts
import Stripe from 'stripe'
import { stripe } from '@/server/lib/stripe'
import { env } from '@/config/env'
import { apiSuccess, apiError } from '@/server/api/response'
import { logger } from '@/server/lib/logger'

export const runtime = 'nodejs'
export const dynamic = 'force-dynamic'

export async function POST(req: Request) {
  const body = await req.text()
  const signature = req.headers.get('stripe-signature')

  if (!signature) return apiError('Missing signature', 400, 'MISSING_SIGNATURE')

  let event: Stripe.Event
  try {
    event = stripe.webhooks.constructEvent(body, signature, env.STRIPE_WEBHOOK_SECRET)
  } catch {
    return apiError('Invalid signature', 400, 'INVALID_SIGNATURE')
  }

  // Respond immediately, process async
  processStripeEvent(event).catch((err) =>
    logger.error({ err, eventId: event.id, type: event.type }, 'Stripe webhook failed')
  )

  return apiSuccess({ received: true })
}
```

