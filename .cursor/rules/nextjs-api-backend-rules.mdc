## 9. Repository Layer

- ALL Mongoose queries happen in repositories only — never in services or handlers.
- ALWAYS call `dbConnect()` at the start of every repository method.
- ALWAYS use `.lean<T>()` on read queries — returns plain JS objects, not Mongoose Documents, which is faster and easier to serialize.
- ALWAYS handle MongoDB-specific errors (duplicate key `code 11000`) and convert to domain errors.
- ALWAYS use explicit field projection with `.select()` — never return the full document.
- ALWAYS paginate `find()` queries with `.skip()` and `.limit()`. Never call `.find()` without a limit.
- ALWAYS use `session` for multi-document transactions.

```typescript
// server/repositories/users.repository.ts
import { dbConnect } from '@/server/lib/db'
import { UserModel, type IUser, type UserResponse } from '@/server/models/User.model'
import { ConflictError, NotFoundError } from '@/server/api/errors'
import type { CreateUserDto, UpdateUserDto } from '@/types/users.types'
import mongoose from 'mongoose'

const USER_PUBLIC_FIELDS = 'id email name role isActive createdAt'

export const userRepository = {
  async findById(id: string): Promise<UserResponse | null> {
    await dbConnect()
    if (!mongoose.Types.ObjectId.isValid(id)) return null
    return UserModel.findById(id).select(USER_PUBLIC_FIELDS).lean<UserResponse>()
  },

  async findByEmail(email: string): Promise<IUser | null> {
    await dbConnect()
    return UserModel.findOne({ email: email.toLowerCase() })
      .select('+password +refreshToken') // Opt-in to select:false fields
      .lean<IUser>()
  },

  async findMany({ page = 1, limit = 20, filter = {} }: {
    page?: number
    limit?: number
    filter?: Record<string, unknown>
  }) {
    await dbConnect()
    const safeLimit = Math.min(limit, 100)
    const skip = (page - 1) * safeLimit

    const [users, total] = await Promise.all([
      UserModel
        .find(filter)
        .select(USER_PUBLIC_FIELDS)
        .sort({ createdAt: -1 })
        .skip(skip)
        .limit(safeLimit)
        .lean<UserResponse[]>(),
      UserModel.countDocuments(filter),
    ])

    return { users, total }
  },

  async create(data: CreateUserDto): Promise<UserResponse> {
    await dbConnect()
    try {
      const user = await UserModel.create(data)
      return user.toJSON() as UserResponse
    } catch (error: any) {
      if (error.code === 11000) throw new ConflictError('User') // Duplicate key
      throw error
    }
  },

  async update(id: string, data: UpdateUserDto): Promise<UserResponse | null> {
    await dbConnect()
    if (!mongoose.Types.ObjectId.isValid(id)) return null
    return UserModel
      .findByIdAndUpdate(id, { $set: data }, { new: true, runValidators: true })
      .select(USER_PUBLIC_FIELDS)
      .lean<UserResponse>()
  },

  async delete(id: string): Promise<boolean> {
    await dbConnect()
    if (!mongoose.Types.ObjectId.isValid(id)) return false
    const result = await UserModel.findByIdAndDelete(id)
    return result !== null
  },

  async updateRefreshToken(id: string, token: string | null): Promise<void> {
    await dbConnect()
    await UserModel.findByIdAndUpdate(id, { $set: { refreshToken: token } })
  },
}
```

