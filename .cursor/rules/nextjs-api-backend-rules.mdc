## 8. Mongoose Models

- ALWAYS define models in `server/models/` directory, one file per model.
- ALWAYS use the `mongoose.models.ModelName || mongoose.model()` pattern to prevent model recompilation errors during hot reload.
- ALWAYS define a TypeScript interface extending `Document` for full type safety.
- ALWAYS use `{ timestamps: true }` on every schema for `createdAt`/`updatedAt`.
- ALWAYS define indexes directly in the schema using `schema.index()` or field-level `index: true`.
- ALWAYS set `{ toJSON: { virtuals: true, versionKey: false } }` to clean up output.
- NEVER return `__v` or raw `_id` to clients — transform them in the schema's `toJSON`.
- ALWAYS use `lean()` in read queries for better performance when you don't need Mongoose document methods.

```typescript
// server/models/User.model.ts
import mongoose, { Schema, Document, Model } from 'mongoose'

export interface IUser extends Document {
  _id: mongoose.Types.ObjectId
  email: string
  name: string
  password: string
  role: 'admin' | 'member' | 'guest'
  refreshToken?: string
  isActive: boolean
  createdAt: Date
  updatedAt: Date
}

// Plain object type for API responses (no Mongoose Document methods)
export interface UserResponse {
  id: string
  email: string
  name: string
  role: string
  isActive: boolean
  createdAt: Date
}

const userSchema = new Schema<IUser>(
  {
    email: {
      type: String,
      required: [true, 'Email is required'],
      unique: true,
      lowercase: true,
      trim: true,
      index: true,
    },
    name: {
      type: String,
      required: [true, 'Name is required'],
      trim: true,
      minlength: 2,
      maxlength: 100,
    },
    password: {
      type: String,
      required: [true, 'Password is required'],
      minlength: 8,
      select: false, // NEVER returned in queries by default
    },
    role: {
      type: String,
      enum: ['admin', 'member', 'guest'],
      default: 'member',
    },
    refreshToken: {
      type: String,
      select: false, // NEVER returned in queries by default
    },
    isActive: {
      type: Boolean,
      default: true,
    },
  },
  {
    timestamps: true,
    toJSON: {
      virtuals: true,
      versionKey: false,
      transform: (_doc, ret) => {
        ret.id = ret._id.toString()
        delete ret._id
        delete ret.password     // Extra safety — never expose password
        delete ret.refreshToken // Extra safety — never expose token
        return ret
      },
    },
  }
)

// Compound indexes for common query patterns
userSchema.index({ email: 1, isActive: 1 })

// Prevent model recompilation in development hot reload
export const UserModel: Model<IUser> =
  mongoose.models.User ?? mongoose.model<IUser>('User', userSchema)
```

```typescript
// server/models/index.ts — barrel export
export { UserModel, type IUser, type UserResponse } from './User.model'
export { PostModel, type IPost } from './Post.model'
```

