## 14. Caching Strategy

- In Next.js 15, GET handlers are dynamic (uncached) by default.
- ALWAYS use `export const revalidate = N` for cacheable public GET routes.
- ALWAYS use `export const dynamic = 'force-dynamic'` for user-specific or auth-required routes.
- ALWAYS use Redis for application-level caching. Use `_id.toString()` as part of cache keys.
- ALWAYS use `revalidateTag()` / `revalidatePath()` after mutations to bust Next.js cache.
- Cache key convention: `{domain}:{entity}:{identifier}` (e.g., `users:profile:64abc123`)

```typescript
// app/api/v1/products/route.ts — public, cacheable
export const runtime = 'nodejs'
export const revalidate = 60

// app/api/v1/users/me/route.ts — user-specific, never cache
export const runtime = 'nodejs'
export const dynamic = 'force-dynamic'

// server/lib/redis.ts
import { Redis } from 'ioredis'
import { env } from '@/config/env'

declare global { var redis: Redis | undefined }

export const redis: Redis =
  global.redis ?? new Redis(env.REDIS_URL, { maxRetriesPerRequest: 3, lazyConnect: true })

if (process.env.NODE_ENV !== 'production') global.redis = redis

export async function withCache<T>(
  key: string,
  ttlSeconds: number,
  fn: () => Promise<T>
): Promise<T> {
  const cached = await redis.get(key)
  if (cached) return JSON.parse(cached) as T
  const data = await fn()
  await redis.setex(key, ttlSeconds, JSON.stringify(data))
  return data
}

export async function invalidateCache(key: string): Promise<void> {
  await redis.del(key)
}
```

