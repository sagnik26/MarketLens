## 19. Logging & Observability

- ALWAYS use Pino. NEVER use `console.log` in production.
- ALWAYS redact sensitive fields: `password`, `token`, `authorization`, `cookie`.
- NEVER log raw MongoDB documents that contain `password` or `refreshToken`.
- ALWAYS expose `/api/health` for uptime monitoring.

```typescript
// server/lib/logger.ts
import pino from 'pino'
import { env } from '@/config/env'

export const logger = pino({
  level: env.LOG_LEVEL,
  redact: [
    'body.password',
    'body.token',
    'body.refreshToken',
    'headers.authorization',
    'headers.cookie',
  ],
  ...(env.NODE_ENV !== 'production' && {
    transport: { target: 'pino-pretty', options: { colorize: true } },
  }),
})

// app/api/health/route.ts
export const runtime = 'nodejs'

export async function GET() {
  return Response.json({
    success: true,
    data: {
      status: 'ok',
      timestamp: new Date().toISOString(),
      version: process.env.npm_package_version,
    },
  })
}
