## 12. Styling

- Use Tailwind CSS as the primary styling solution.
- ALWAYS use `cn()` (from `clsx` + `tailwind-merge`) for conditional class merging. NEVER string-concatenate class names.
- NEVER use inline `style` props except for truly dynamic values not achievable with Tailwind (CSS custom properties).
- Use `cva` (class-variance-authority) for component variant definitions.
- ALWAYS implement responsive design with a mobile-first approach.
- Use CSS variables via Tailwind's config for theming (colors, radius, spacing).

```typescript
// lib/utils.ts
import { clsx, type ClassValue } from "clsx";
import { twMerge } from "tailwind-merge";

export function cn(...inputs: ClassValue[]) {
  return twMerge(clsx(inputs));
}

// ✅ Good — cva for variants
import { cva, type VariantProps } from "class-variance-authority";

const buttonVariants = cva(
  "inline-flex items-center justify-center rounded-md font-medium transition-colors",
  {
    variants: {
      variant: {
        default: "bg-primary text-primary-foreground hover:bg-primary/90",
        outline: "border border-input bg-transparent hover:bg-accent",
        aceternity:
          "relative overflow-hidden border border-white/20 bg-black text-white",
      },
      size: {
        sm: "h-8 px-3 text-sm",
        md: "h-10 px-4",
        lg: "h-12 px-6 text-lg",
      },
    },
    defaultVariants: { variant: "default", size: "md" },
  },
);
```

