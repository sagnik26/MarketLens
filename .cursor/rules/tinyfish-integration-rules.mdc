## SSE STREAM PARSING

The `run-sse` endpoint streams Server-Sent Events. See [API Reference (SSE)](https://docs.tinyfish.ai/api-reference/automation/run-browser-automation-with-sse-streaming).

The final `COMPLETE` event carries **`resultJson`** (not `result`) with extracted data. Handle `event.status` (`COMPLETED` | `FAILED` | `CANCELLED`) and optional `event.error`.

```typescript
// lib/tinyfish/sse-parser.ts

export interface TinyFishSSEResult {
  success: boolean;
  resultJson: unknown; // Validate with Zod before use
  status: string;
  rawEvents: TinyFishSSEEvent[];
}

export interface TinyFishSSEEvent {
  type: string;
  status?: string;
  resultJson?: unknown;
  message?: string;
}

async function parseSSEStream(response: Response) {
  if (!response.body) {
    throw new Error("No response body received from TinyFish");
  }

  const reader = response.body.getReader();
  const decoder = new TextDecoder();

  let buffer = "";
  const events: any[] = [];

  let finalResult: any = null;
  let failed = false;
  let failureReason: string | null = null;

  while (true) {
    const { done, value } = await reader.read();
    if (done) break;

    buffer += decoder.decode(value, { stream: true });

    // Split on SSE event boundary
    const parts = buffer.split("\n\n");
    buffer = parts.pop() || "";

    for (const part of parts) {
      const line = part.trim();

      if (!line.startsWith("data:")) continue;

      const jsonString = line.replace(/^data:\s*/, "").trim();

      if (!jsonString) continue;

      try {
        const event = JSON.parse(jsonString);
        events.push(event);

        // ---- FAILURE DETECTION ----
        if (
          event.type === "ERROR" ||
          event.status === "FAILED" ||
          event.status === "CANCELLED" ||
          (event.type === "COMPLETE" && event.status !== "COMPLETED")
        ) {
          failed = true;
          failureReason =
            event.error ?? event.message ?? event.help_message ?? "TinyFish reported failure";
        }

        // ---- RESULT DETECTION (docs: COMPLETE event has resultJson) ----
        if (event.type === "COMPLETE" && event.resultJson !== undefined && event.resultJson !== null) {
          finalResult = event.resultJson;
        }
      } catch (err) {
        console.warn("Failed to parse SSE chunk:", jsonString);
      }
    }
  }

  const hasResult = finalResult !== null;

  return {
    success: hasResult && !failed,
    status: failed ? "FAILED" : hasResult ? "COMPLETED" : "IN_PROGRESS",
    resultJson: finalResult,
    error: failureReason,
    rawEvents: events,
  };
}
```

### SSE Parsing Rules

- ALWAYS call `reader.releaseLock()` in `finally` block
- ALWAYS wrap line parser in `try/catch` — skip malformed lines silently
- NEVER throw from inside the stream reader loop
- Only the `COMPLETE` event carries `resultJson` (API field name; do not use `result` for SSE)
- Use `event.status` for COMPLETED / FAILED / CANCELLED; use `event.error` for failure reason
- Forward progress events (`PROGRESS`, `STREAMING_URL`) to your own SSE route for live UI updates

